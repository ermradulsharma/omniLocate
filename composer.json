{
    "name": "skywalker-labs/location",
    "description": "OmniLocate: Advanced user location detection for Laravel with persistence, caching, and distance utilities.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "geo-location",
        "geoIP",
        "laravel",
        "location",
        "omnilocate",
        "persistence",
        "php",
        "skywalker"
    ],
    "homepage": "https://github.com/skywalker-labs/location",
    "support": {
        "issues": "https://github.com/skywalker-labs/location/issues",
        "source": "https://github.com/skywalker-labs/location",
        "wiki": "https://github.com/skywalker-labs/location/wiki"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/ermradulsharma"
        }
    ],
    "authors": [
        {
            "name": "Mradul Sharma",
            "email": "skywalkerlknw@gmail.com",
            "homepage": "https://mradulsharma.vercel.app/",
            "role": "Lead Developer"
        },
        {
            "name": "Skywalker Labs Team",
            "email": "skywalkerlknw@gmail.com",
            "homepage": "https://skywalker-labs.com/",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "ext-curl": "*",
        "ext-json": "*",
        "geoip2/geoip2": "^2.10 || ^3.0",
        "skywalker-labs/toolkit": "^1.6.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.4.4",
        "orchestra/testbench": "^6.0 || ^7.0 || ^8.0 || ^9.0 || ^10.0",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^9.5 || ^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Skywalker\\Location\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Skywalker\\Location\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Skywalker\\Location\\LocationServiceProvider"
            ],
            "aliases": {
                "Location": "Skywalker\\Location\\Facades\\Location"
            }
        }
    },
    "scripts": {
        "analyze": "vendor/bin/phpstan analyze",
        "format": "vendor/bin/pint",
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}